# Copy this file to ".env" and adjust as needed.

# App display name (login screen, receipts)
APP_NAME=Hardware ERP

# Secret used to sign session cookies. CHANGE THIS for the client install.
SECRET_KEY=change-me-in-production

# Initial admin account, created automatically on first startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Database connection.
# - Inside Docker Compose the app talks to the "db" service on 5432 (set there).
# - For running the app OUTSIDE Docker against the Docker Postgres, use 5433:
# DATABASE_URL=postgresql+psycopg2://erp:erp@localhost:5433/hardware_erp

# ---------------------------------------------------------------------------
# Automatic daily backups
# ---------------------------------------------------------------------------
# Where the daily .sql backup files are written. Defaults to a "backups" folder
# next to the app.
#
# IMPORTANT: a backup on the same drive as the app is lost if that drive dies.
# Once the external hard drive is connected, point this at it instead, e.g.:
#   BACKUP_DIR=D:/erp-backups
# (use forward slashes, and make sure the folder already exists)
BACKUP_DIR=./backups

# How many days of backups to keep. Older ones are deleted automatically.
BACKUP_KEEP_DAYS=14
